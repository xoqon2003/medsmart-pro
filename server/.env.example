# ═══════════════════════════════════════════════════════════════
# MedSmart Pro — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════

# Database (PostgreSQL via Supabase)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_KEY="YOUR_SERVICE_KEY"

# JWT Authentication
JWT_SECRET="medsmart-pro-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000

# Redis (caching va background jobs uchun)
REDIS_URL="redis://localhost:6379"

# Telegram Bot (Mini App auth uchun)
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Eskiz.uz SMS Gateway (OTP uchun)
ESKIZ_EMAIL="YOUR_ESKIZ_EMAIL"
ESKIZ_PASSWORD="YOUR_ESKIZ_PASSWORD"

# Payme (to'lov integratsiyasi)
PAYME_MERCHANT_ID="YOUR_PAYME_MERCHANT_ID"
PAYME_MERCHANT_KEY="YOUR_PAYME_MERCHANT_KEY"
PAYME_TEST_MODE="true"

# Click (to'lov integratsiyasi)
CLICK_MERCHANT_ID="YOUR_CLICK_MERCHANT_ID"
CLICK_SERVICE_ID="YOUR_CLICK_SERVICE_ID"
CLICK_SECRET_KEY="YOUR_CLICK_SECRET_KEY"

# Uzum Bank (to'lov integratsiyasi)
UZUM_TERMINAL_ID="YOUR_UZUM_TERMINAL_ID"
UZUM_CASH_ID="YOUR_UZUM_CASH_ID"
UZUM_SECRET_KEY="YOUR_UZUM_SECRET_KEY"

# ═══════════════════════════════════════════════════════════════
# Disease Knowledge Base Moduli (docs/09-modules/disease-kb-module.md)
# ═══════════════════════════════════════════════════════════════

# Kasalliklar moduli feature flag — prod'da `false`, staging/dev'da `true`
APP_FEATURE_DISEASE_KB="false"

# KB moderatsiya uchun BullMQ navbat nomi
KB_MODERATION_QUEUE_NAME="kb-moderation"

# Boshlang'ich ma'lumotlar (seed) papkasi — 50 kasallik MVP uchun
KB_SEED_PATH="./prisma/seeds/diseases"
