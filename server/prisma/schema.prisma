generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PATIENT
  RADIOLOG
  DOCTOR
  SPECIALIST
  OPERATOR
  ADMIN
  KASSIR
  // ── Disease KB roles (PR-05) ───────────────────────────────────────────────
  STUDENT
  NURSE
  EDITOR
  MEDICAL_EDITOR
}

enum Gender {
  MALE
  FEMALE
}

enum Language {
  UZ
  RU
}

enum AppStatus {
  NEW
  PAID_PENDING
  ACCEPTED
  EXTRA_INFO_NEEDED
  WITH_SPECIALIST
  CONCLUSION_WRITING
  DONE
  FAILED
  ARCHIVED
  HV_ONWAY
  HV_ARRIVED
}

enum ServiceType {
  AI_RADIOLOG
  RADIOLOG_ONLY
  RADIOLOG_SPECIALIST
  CONSULTATION
  HOME_VISIT
}

enum Urgency {
  NORMAL
  URGENT
  EMERGENCY
}

enum PaymentProvider {
  PERSONAL_CARD
  PAYME
  CLICK
  UZUM
  UZCARD
  HUMO
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ConclusionType {
  AI_ANALYSIS
  RADIOLOG
  SPECIALIST
  DOCTOR
}

enum FileType {
  DICOM
  IMAGE
  PDF
  OTHER
}

enum KassaTolovUsuli {
  NAQD
  KARTA
  PAYME
  CLICK
  UZUM
  UZCARD
  HUMO
  TERMINAL
}

enum KassaTolovHolati {
  KUTILMOQDA
  QABUL_QILINDI
  BEKOR
  QAYTARILDI
}

enum SmenaHolati {
  OCHIQ
  YOPIQ
}

enum TariffCode {
  FREE
  START
  LITE
  PREMIUM
}

enum OperationComplexity {
  SIMPLE
  MEDIUM
  COMPLEX
  VERY_COMPLEX
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ── Auth Models ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  telegramId       BigInt?   @unique
  username         String?
  phone            String    @unique
  pin              String?
  fullName         String
  role             UserRole
  gender           Gender?
  birthDate        String?
  city             String?
  chronicDiseases  String?
  language         Language  @default(UZ)
  isActive         Boolean   @default(true)
  avatar           String?
  license          String?
  specialty        String?
  experience       Int?
  rating           Float?
  totalConclusions   Int?               @default(0)
  isOnline           Boolean            @default(false)
  lastSeenAt         DateTime?
  profileUrl         String?            @unique
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())

  // Relations
  patientApps      Application[] @relation("PatientApps")
  radiologApps     Application[] @relation("RadiologApps")
  specialistApps   Application[] @relation("SpecialistApps")
  doctorApps       Application[] @relation("DoctorApps")
  conclusions      Conclusion[]
  notifications    Notification[]
  kassaSmenas      KassaSmena[]
  kassaTolovlar    KassaTolov[]  @relation("KassirTolov")
  auditEvents      AuditEvent[]
  doctorProfile    DoctorProfile?
  contactRequests  ContactRequest[] @relation("PatientContacts")
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  chatMessages     ChatMessage[]      @relation("ChatSentMessages")
  messagePermissions   MessagePermission[]    @relation("PatientPermissions")
  consultationRequests ConsultationRequest[]  @relation("PatientConsultations")
  refreshTokens        RefreshToken[]

  // Lab, Pharmacy, EMR relations
  patientLabOrders     LabOrder[]         @relation("PatientLabOrders")
  doctorLabOrders      LabOrder[]         @relation("DoctorLabOrders")
  patientPrescriptions Prescription[]     @relation("PatientPrescriptions")
  doctorPrescriptions  Prescription[]     @relation("DoctorPrescriptions")
  patientRecords       MedicalRecord[]    @relation("PatientMedicalRecords")
  doctorRecords        MedicalRecord[]    @relation("DoctorMedicalRecords")
  allergies            Allergy[]          @relation("PatientAllergies")

  // ── Disease KB relations (PR-04) ────────────────────────────────────────
  diseaseNotes         UserDiseaseNote[]
  diseaseEditLogs      DiseaseEditLog[]           @relation("DiseaseEditor")
  sentMatchSessions    SymptomMatchSession[]      @relation("MatchSessionUser")
  receivedMatchSessions SymptomMatchSession[]     @relation("MatchSessionDoctor")
  aiTriageSessions     AITriageSession[]
  publishedCases       ClinicalCase[]             @relation("ClinicalCasePublisher")

  @@index([role])
  @@index([phone])
}

model Application {
  id              Int         @id @default(autoincrement())
  arizaNumber     String      @unique
  patientId       Int
  radiologId      Int?
  specialistId    Int?
  doctorId        Int?
  status          AppStatus   @default(NEW)
  serviceType     ServiceType
  urgency         Urgency     @default(NORMAL)
  scanType        String?
  organ           String?
  scanDate        String?
  scanFacility    String?
  price           Decimal     @db.Decimal(12, 2)
  notes           String?
  rating          Int?
  ratingComment   String?
  deadlineAt      DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Uyga chaqirish
  hvClinicName       String?
  hvDoctorName       String?
  hvDoctorSpeciality String?
  hvVisitDay         String?
  hvTimeSlot         String?
  hvAddress          String?

  // Relations
  patient         User         @relation("PatientApps", fields: [patientId], references: [id])
  radiolog        User?        @relation("RadiologApps", fields: [radiologId], references: [id])
  specialist      User?        @relation("SpecialistApps", fields: [specialistId], references: [id])
  doctor          User?        @relation("DoctorApps", fields: [doctorId], references: [id])
  anamnez         Anamnez?
  files           FileRecord[]
  payment         Payment?
  conclusions     Conclusion[]
  auditLog        AuditEvent[]
  examinations    Examination[]
  kassaTolovlar   KassaTolov[]
  labOrders       LabOrder[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]

  @@index([patientId])
  @@index([status])
  @@index([radiologId])
  @@index([createdAt])
}

model Anamnez {
  id                Int         @id @default(autoincrement())
  applicationId     Int         @unique
  complaint         String
  duration          String?
  hasPain           Boolean     @default(false)
  painLevel         Int?
  previousTreatment String?
  medications       String?
  allergies         String?
  additionalInfo    String?

  application       Application @relation(fields: [applicationId], references: [id])
}

model FileRecord {
  id              Int         @id @default(autoincrement())
  applicationId   Int
  fileType        FileType
  originalName    String
  s3Key           String
  sizeBytes       BigInt
  mimeType        String
  preview         String?
  uploadedAt      DateTime    @default(now())

  application     Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model Payment {
  id                    Int            @id @default(autoincrement())
  applicationId         Int            @unique
  amount                Decimal        @db.Decimal(12, 2)
  provider              PaymentProvider
  providerTransactionId String?
  status                PaymentStatus  @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime       @default(now())

  application           Application    @relation(fields: [applicationId], references: [id])
}

model Conclusion {
  id              Int            @id @default(autoincrement())
  applicationId   Int
  authorId        Int
  conclusionType  ConclusionType
  description     String
  findings        String
  impression      String
  recommendations String?
  source          String?
  aiAnalysis      Json?
  pdfUrl          String?
  signedAt        DateTime       @default(now())

  application     Application    @relation(fields: [applicationId], references: [id])
  author          User           @relation(fields: [authorId], references: [id])

  @@index([applicationId])
}

model AuditEvent {
  id              Int       @id @default(autoincrement())
  applicationId   Int
  action          String
  actorId         Int?
  actorRole       String?
  actorName       String?
  details         Json?
  createdAt       DateTime  @default(now())

  application     Application @relation(fields: [applicationId], references: [id])
  actor           User?       @relation(fields: [actorId], references: [id])

  @@index([applicationId])
}

model Notification {
  id              Int       @id @default(autoincrement())
  userId          Int
  title           String
  message         String
  type            String    @default("info")
  isRead          Boolean   @default(false)
  applicationId   Int?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Examination {
  id               Int       @id @default(autoincrement())
  applicationId    Int
  category         String
  instrumentalType String?
  labTypes         String[]
  organ            String?
  dateStatus       String    @default("unknown")
  dateYmd          String?
  approxYear       String?
  facility         String?
  createdAt        DateTime  @default(now())

  application      Application @relation(fields: [applicationId], references: [id])
}

model KassaSmena {
  id               Int         @id @default(autoincrement())
  kassirId         Int
  kassirIsmi       String
  ochilganVaqt     DateTime    @default(now())
  yopilganVaqt     DateTime?
  boshlanghichQoldiq Decimal   @db.Decimal(12, 2) @default(0)
  naqd             Decimal     @db.Decimal(12, 2) @default(0)
  karta            Decimal     @db.Decimal(12, 2) @default(0)
  onlayn           Decimal     @db.Decimal(12, 2) @default(0)
  jami             Decimal     @db.Decimal(12, 2) @default(0)
  tolovlarSoni     Int         @default(0)
  holati           SmenaHolati @default(OCHIQ)

  kassir           User        @relation(fields: [kassirId], references: [id])
  tolovlar         KassaTolov[]

  @@index([kassirId])
}

model KassaTolov {
  id              Int              @id @default(autoincrement())
  smenaId         Int
  applicationId   Int
  invoiceRaqam    String           @unique
  bemorIsmi       String
  xizmatNomi      String
  summa           Decimal          @db.Decimal(12, 2)
  chegirma        Decimal          @db.Decimal(12, 2) @default(0)
  tolashKerak     Decimal          @db.Decimal(12, 2)
  tolanganSumma   Decimal          @db.Decimal(12, 2)
  qaytim          Decimal          @db.Decimal(12, 2) @default(0)
  tolovUsuli      KassaTolovUsuli
  holati          KassaTolovHolati @default(KUTILMOQDA)
  kassirId        Int
  izoh            String?
  sanaVaqt        DateTime         @default(now())

  smena           KassaSmena       @relation(fields: [smenaId], references: [id])
  application     Application      @relation(fields: [applicationId], references: [id])
  kassir          User             @relation("KassirTolov", fields: [kassirId], references: [id])
}

// ── Statik ma'lumotlar uchun jadvallar ───────────────────────────────────────

model ExaminationCenter {
  id          Int    @id @default(autoincrement())
  name        String
  region      String
  district    String
  rating      Float  @default(0)
  price       Int    @default(0)
  distanceKm  Float  @default(0)

  @@index([region, district])
}

model BookingSlot {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      String
  time      String
  status    String   @default("free")

  @@unique([doctorId, date, time])
}

// ── TZ-01: Shifokor Profili va Tarif Tizimi ──────────────────────────────────

model Tariff {
  id          String         @id @default(uuid())
  name        String
  code        TariffCode     @unique
  price       Int            @default(0)
  features    Json
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  description String?
  doctors     DoctorProfile[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Clinic {
  id            String         @id @default(uuid())
  name          String
  address       String
  city          String?
  region        String?
  phone         String?
  email         String?
  website       String?
  isVerified    Boolean        @default(false)
  verifiedBy    Int?
  latitude      Float?
  longitude     Float?
  servicesCount Int            @default(0)
  isTop         Boolean        @default(false)
  topPriority   Int            @default(0)
  topExpiresAt  DateTime?
  logoUrl       String?
  rating        Float          @default(0)
  description   String?
  doctors       DoctorClinic[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DoctorProfile {
  id                    String   @id @default(uuid())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id])

  bio                   String?  @db.Text
  birthDate             DateTime?
  experienceYears       Int      @default(0)
  subSpecialties        String[] @default([])
  qualificationCategory String?
  qualificationDocUrl   String?
  licenseNumber         String?
  licenseDocUrl         String?
  licenseVerified       Boolean  @default(false)
  qualificationVerified Boolean  @default(false)
  socialLinks           Json?
  profileUrl            String?  @unique
  isPublic              Boolean  @default(true)
  isBusinessAccount     Boolean  @default(false)

  tariffId              String?
  tariff                Tariff?  @relation(fields: [tariffId], references: [id])

  clinics               DoctorClinic[]
  operationTypes        DoctorOperationType[]
  education             Education[]
  workExperience        WorkExperience[]
  achievements          Achievement[]
  certificates          Certificate[]
  contactRequests       ContactRequest[]
  messageTemplates      MessageTemplate[]
  messagePermissions    MessagePermission[] @relation("DoctorPermissions")
  faq                   FAQ[]
  medicalServices       MedicalService[]
  anonymousNumber       AnonymousNumber?
  callSchedule          CallSchedule?
  telegramBotConfig     TelegramBotConfig?
  adSetting             AdSetting?
  calendarSetting       CalendarSetting?
  calendarSlots         CalendarSlot[]
  consultationRequests  ConsultationRequest[] @relation("DoctorConsultations")

  totalConsultations    Int   @default(0)
  totalOperations       Int   @default(0)
  onlineConsultations   Int   @default(0)
  offlineConsultations  Int   @default(0)
  averageRating         Float @default(0)
  totalRatings          Int   @default(0)
  overallRank           Int?
  specialtyRank         Int?

  // ── Disease KB (PR-04) ─────────────────────────────────────────────────
  diseaseSpecialties    DiseaseSpecialty[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DoctorClinic {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  clinicId   String
  clinic     Clinic        @relation(fields: [clinicId], references: [id])
  position   String?
  department String?
  cabinet    String?
  floor      Int?
  isVerified Boolean       @default(false)
  verifiedBy Int?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())

  @@unique([doctorId, clinicId])
}

model DoctorOperationType {
  id              String              @id @default(uuid())
  doctorId        String
  doctor          DoctorProfile       @relation(fields: [doctorId], references: [id])
  operationCode   String
  operationName   String
  operationNameRu String?
  category        String
  complexity      OperationComplexity @default(MEDIUM)
  avgDurationMin  Int?
  description     String?
  count           Int                 @default(0)
  createdAt       DateTime            @default(now())

  @@unique([doctorId, operationCode])
}

// ── TZ-02: Professional Portfolio ───────────────────────────────────────────

model Education {
  id              String        @id @default(uuid())
  doctorId        String
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id])
  institutionName String
  faculty         String?
  degree          String        // BACHELOR, MASTER, PHD, DSC, RESIDENCY, ORDINATURA
  startYear       Int
  endYear         Int?
  diplomaNumber   String?
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([doctorId])
}

model WorkExperience {
  id               String        @id @default(uuid())
  doctorId         String
  doctor           DoctorProfile @relation(fields: [doctorId], references: [id])
  organizationName String
  position         String
  department       String?
  startYear        Int
  endYear          Int?          // null = hozir ishlaydi
  description      String?
  createdAt        DateTime      @default(now())

  @@index([doctorId])
}

model Achievement {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  name        String
  nameRu      String?
  group       String        // SCIENTIFIC, PRACTICAL, ORGANIZATIONAL, INTERNATIONAL, STATE
  year        Int
  description String?
  documentUrl String?
  stickerType String?       // GOLD, SILVER, BRONZE, SPECIAL
  isVerified  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([doctorId])
}

model Certificate {
  id             String        @id @default(uuid())
  doctorId       String
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  name           String
  nameRu         String?
  organization   String
  direction      String
  year           Int
  certificateNum String?
  documentUrl    String?
  expiresAt      DateTime?
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([doctorId])
}

// ── TZ-04: Ariza Qoldirish va Aloqa ────────────────────────────────────────

model ContactRequest {
  id            String        @id @default(uuid())
  doctorId      String
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  patientId     Int?
  patient       User?         @relation("PatientContacts", fields: [patientId], references: [id])
  patientName   String
  patientPhone  String
  patientEmail  String?
  requestType   String        // CONSULTATION, COMPLAINT, FOLLOW_UP, OTHER
  message       String        @db.Text
  templateUsed  String?
  status        String        @default("NEW") // NEW, READ, REPLIED, ARCHIVED
  doctorReply   String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([doctorId])
  @@index([status])
}

model MessageTemplate {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  category   String        // COMPLAINT, SYMPTOM, FOLLOW_UP
  title      String
  content    String        @db.Text
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  usageCount Int           @default(0)
  createdAt  DateTime      @default(now())

  @@index([doctorId])
}

// ── TZ-05: Xabar Yuborish Tizimi ───────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    Int
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  Int
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String?  @db.Text
  messageType String   @default("TEXT") // TEXT, IMAGE, FILE, VOICE
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  consultId   String?
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model MessagePermission {
  id              String        @id @default(uuid())
  patientId       Int
  patient         User          @relation("PatientPermissions", fields: [patientId], references: [id])
  doctorId        String
  doctor          DoctorProfile @relation("DoctorPermissions", fields: [doctorId], references: [id])
  consultationId  String?
  grantedBy       String        // AUTO, DOCTOR
  status          String        @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, REQUESTED
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([patientId, doctorId])
}

// ── TZ-06: FAQ va Tibbiy Xizmatlar ─────────────────────────────────────────

model FAQ {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  question   String
  questionRu String?
  answer     String        @db.Text
  answerRu   String?       @db.Text
  category   String        // OPERATION, RECOVERY, COSTS, CONSULTATION, DIAGNOSTICS
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  viewCount  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([doctorId])
}

model MedicalService {
  id             String        @id @default(uuid())
  doctorId       String
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  name           String
  nameRu         String?
  category       String        // INSTRUMENTAL, LABORATORY, OPERATION, CONSULTATION, DIAGNOSTICS
  price          Int?
  priceFrom      Int?
  priceTo        Int?
  description    String?       @db.Text
  descriptionRu  String?       @db.Text
  targetAudience String?
  preparation    String?
  duration       String?
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([doctorId])
}

// ── TZ-07: Qo'shimcha Funksionallar ────────────────────────────────────────

model AnonymousNumber {
  id            String        @id @default(uuid())
  doctorId      String        @unique
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  virtualNumber String?
  realNumber    String?
  provider      String?       // TWILIO, LOCAL_SIP
  isActive      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CallSchedule {
  id         String        @id @default(uuid())
  doctorId   String        @unique
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  workDays   Int[]         @default([1, 2, 3, 4, 5])
  startTime  String        @default("09:00")
  endTime    String        @default("18:00")
  lunchStart String?       @default("13:00")
  lunchEnd   String?       @default("14:00")
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model TelegramBotConfig {
  id         String        @id @default(uuid())
  doctorId   String        @unique
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  botToken   String?
  channelId  String?
  channelUrl String?
  isOwnBot   Boolean       @default(false)
  autoPost   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model AdSetting {
  id            String        @id @default(uuid())
  doctorId      String        @unique
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  showBannerAds Boolean       @default(true)
  showPopupAds  Boolean       @default(true)
  showInFeedAds Boolean       @default(true)
  adFrequency   String        @default("NORMAL") // NONE, MINIMAL, NORMAL, FULL
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ── TZ-03: Kalendar va Konsultatsiya ────────────────────────────────────────

model CalendarSetting {
  id             String        @id @default(uuid())
  doctorId       String        @unique
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  workDays       Int[]         @default([1, 2, 3, 4, 5])
  startTime      String        @default("09:00")
  endTime        String        @default("18:00")
  slotDuration   Int           @default(30)
  breakDuration  Int           @default(10)
  consultTypes   String[]      @default(["OFFLINE", "ONLINE"])
  onlinePrice    Int           @default(0)
  offlinePrice   Int           @default(0)
  phonePrice     Int           @default(0)
  videoPrice     Int           @default(0)
  maxPatientsDay Int           @default(20)
  officeAddress  String?
  officeName     String?
  officeFloor    Int?
  officeCabinet  String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model CalendarSlot {
  id           String              @id @default(uuid())
  doctorId     String
  doctor       DoctorProfile       @relation(fields: [doctorId], references: [id])
  date         DateTime
  startTime    String
  endTime      String
  status       String              @default("FREE") // FREE, BOOKED, BLOCKED, CANCELLED
  blockedBy    String?
  blockReason  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  consultation ConsultationRequest?

  @@index([doctorId, date])
  @@index([status])
}

model ConsultationRequest {
  id            String        @id @default(uuid())
  patientId     Int
  patient       User          @relation("PatientConsultations", fields: [patientId], references: [id])
  doctorId      String
  doctor        DoctorProfile @relation("DoctorConsultations", fields: [doctorId], references: [id])
  slotId        String        @unique
  slot          CalendarSlot  @relation(fields: [slotId], references: [id])
  consultType   String        // OFFLINE, ONLINE, PHONE, VIDEO
  status        String        @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, RESCHEDULED
  patientName   String?
  patientPhone  String?
  patientEmail  String?
  reason        String?
  cancelReason  String?
  cancelledBy   String?       // PATIENT, DOCTOR
  rescheduledTo String?
  meetingUrl    String?
  price         Int           @default(0)
  isPaid        Boolean       @default(false)
  rating        Float?
  comment       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

// ── Laboratoriya Moduli ─────────────────────────────────────────────────────

enum LabTestStatus {
  PENDING
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model LabOrder {
  id            String        @id @default(uuid())
  patientId     Int
  patient       User          @relation("PatientLabOrders", fields: [patientId], references: [id])
  doctorId      Int?
  doctor        User?         @relation("DoctorLabOrders", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application?  @relation(fields: [applicationId], references: [id])
  status        LabTestStatus @default(PENDING)
  totalPrice    Int           @default(0)
  notes         String?
  sampleDate    DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tests         LabTest[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model LabTest {
  id          String        @id @default(uuid())
  orderId     String
  order       LabOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testCode    String
  testName    String
  category    String        // BLOOD, URINE, HORMONE, BIOCHEMISTRY, etc.
  status      LabTestStatus @default(PENDING)
  result      Json?
  resultText  String?
  normalRange String?
  unit        String?
  price       Int           @default(0)
  // ── Disease KB extension (PR-03) ──────────────────────────────────────────
  loincCode   String?       // LOINC terminology code
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([category])
}

// ── Dorixona Moduli ─────────────────────────────────────────────────────────

enum PrescriptionStatus {
  ACTIVE
  FILLED
  PARTIALLY_FILLED
  EXPIRED
  CANCELLED
}

model Prescription {
  id            String             @id @default(uuid())
  patientId     Int
  patient       User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctorId      Int
  doctor        User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application?       @relation(fields: [applicationId], references: [id])
  status        PrescriptionStatus @default(ACTIVE)
  diagnosis     String?
  notes         String?
  validUntil    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  items         PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String?
  medicine       Medicine?    @relation(fields: [medicineId], references: [id])
  medicineName   String
  dosage         String       // "500mg"
  frequency      String       // "2 marta kuniga"
  duration       String       // "7 kun"
  quantity       Int          @default(1)
  instructions   String?      // "Ovqatdan keyin"
  isFilled       Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([prescriptionId])
}

model Medicine {
  id              String             @id @default(uuid())
  name            String
  nameRu          String?
  genericName     String?
  manufacturer    String?
  category        String             // ANTIBIOTIC, PAINKILLER, VITAMIN, etc.
  form            String             // TABLET, CAPSULE, SYRUP, INJECTION, etc.
  dosage          String?            // "500mg"
  price           Int                @default(0)
  inStock         Boolean            @default(true)
  stockQuantity   Int                @default(0)
  requiresRx      Boolean            @default(false) // Retsept talab qiladimi
  description     String?
  sideEffects     String?
  contraindications String?
  isActive        Boolean            @default(true)
  // ── Disease KB extensions (PR-03) ─────────────────────────────────────────
  rxnormCode      String?            // RxNorm terminology code
  innName         String?            // International Nonproprietary Name (WHO INN)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  prescriptionItems PrescriptionItem[]
  diseaseLinks    DiseaseMedication[]

  @@index([category])
  @@index([name])
}

// ── EMR (Kasallik Tarixi) Moduli ────────────────────────────────────────────

model MedicalRecord {
  id            String    @id @default(uuid())
  patientId     Int
  patient       User      @relation("PatientMedicalRecords", fields: [patientId], references: [id])
  doctorId      Int
  doctor        User      @relation("DoctorMedicalRecords", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])
  recordType    String    // CONSULTATION, EXAMINATION, DIAGNOSIS, PROCEDURE, FOLLOW_UP
  icdCode       String?   // ICD-10 kasallik kodi
  diagnosis     String?
  symptoms      String[]
  findings      String?
  treatment     String?
  notes         String?
  vitals        Json?     // { bloodPressure, heartRate, temperature, weight, height }
  attachments   String[]  // fayl URL lari
  isConfidential Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([icdCode])
  @@index([recordType])
}

model Allergy {
  id         String   @id @default(uuid())
  patientId  Int
  patient    User     @relation("PatientAllergies", fields: [patientId], references: [id])
  allergen   String
  severity   String   // MILD, MODERATE, SEVERE
  reaction   String?
  notes      String?
  reportedAt DateTime @default(now())

  @@index([patientId])
  @@unique([patientId, allergen])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ── Disease Knowledge Base Module ──────────────────────────────────────────────
// PR-02..PR-06 (see docs/analysis/implementation-plan.md §3 Faza 0)
// Frontend type mapping (src/app/types/index.ts):
//   KBApprovalStatus 'draft'|'review'|'approved'|'rejected'  ↔  ApprovalStatus DRAFT|REVIEW|APPROVED|REJECTED
//   (backend adds PUBLISHED + ARCHIVED as additional lifecycle states).
//   EvidenceLevel 'A'|'B'|'C'|'D'                            ↔  EvidenceLevel A|B|C|D
// ═══════════════════════════════════════════════════════════════════════════════

// ── KB Enums (PR-02) ───────────────────────────────────────────────────────────

enum ApprovalStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum EvidenceLevel {
  A
  B
  C
  D
}

enum ContentLevel {
  L1
  L2
  L3
}

enum AudienceMode {
  PATIENT
  STUDENT
  NURSE
  DOCTOR
  SPECIALIST
  MIXED
}

enum DiseaseSeverity {
  MILD
  MODERATE
  SEVERE
}

enum SymptomSeverity {
  MILD
  MODERATE
  SEVERE
  CRITICAL
}

enum ReferenceType {
  DOI
  PUBMED
  URL
  WHO
  PROTOCOL
  BOOK
  LOCAL_PROTOCOL
}

// ── KB Enums (PR-03) ───────────────────────────────────────────────────────────

enum StageType {
  EARLY
  EXPANDED
  LATE
}

enum MedicationVisibility {
  PATIENT
  STUDENT
  DOCTOR
}

enum LabTestPriority {
  MINIMUM
  EXTENDED
}

enum TranslationStatus {
  AUTO
  REVIEWED
  VERIFIED
  PENDING
}

// ── KB Enums (PR-04) ───────────────────────────────────────────────────────────

enum SymptomAnswer {
  YES
  NO
  UNKNOWN
  SOMETIMES
}

enum MatchSessionStatus {
  ACTIVE
  SENT_TO_DOCTOR
  EXPIRED
  ARCHIVED
}

enum EditLogType {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

// ── KB Enums (v2 extensions: scientists, research, genetics) ──────────────────

enum ScientistRole {
  DISCOVERER
  CLASSIFIER
  CONTRIBUTOR
  RESEARCHER
  EDITOR
}

enum ResearchType {
  RCT
  META_ANALYSIS
  SYSTEMATIC_REVIEW
  COHORT
  CASE_CONTROL
  CASE_SERIES
  CASE_REPORT
  GUIDELINE
}

enum InheritancePattern {
  AUTOSOMAL_DOMINANT
  AUTOSOMAL_RECESSIVE
  X_LINKED_DOMINANT
  X_LINKED_RECESSIVE
  MITOCHONDRIAL
  COMPLEX
  SPORADIC
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

// ── Disease (PR-02) ────────────────────────────────────────────────────────────

model Disease {
  id                String           @id @default(uuid())
  slug              String           @unique
  icd10             String           @unique
  icd11             String?
  nameUz            String
  nameRu            String?
  nameEn            String?
  nameLat           String?
  synonyms          String[]         @default([])
  category          String
  audienceLevels    AudienceMode[]   @default([])
  severityLevels    DiseaseSeverity[] @default([])
  protocolSources   String[]         @default([])
  status            ApprovalStatus   @default(DRAFT)
  editorId          Int?
  // ── FTS (PR-06) ────────────────────────────────────────────────────────
  searchVector      Unsupported("tsvector")?
  // ── pgvector: 1536-dimension OpenAI embedding (PR-07) ─────────────────
  embedding         Unsupported("vector(1536)")?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  diseaseSymptoms   DiseaseSymptom[]
  references        DiseaseReference[]
  blocks            DiseaseBlock[]
  stages            DiseaseStage[]
  medications       DiseaseMedication[]
  labTests          DiseaseLabTest[]
  clinicalCases     ClinicalCase[]
  userNotes         UserDiseaseNote[]
  matchSessions     SymptomMatchSession[]
  editLogs          DiseaseEditLog[]
  epidemiology      RegionEpidemiology[]
  specialties       DiseaseSpecialty[]
  scientists        DiseaseScientist[]
  research          DiseaseResearch[]
  genetics          DiseaseGenetic[]

  @@index([category])
  @@index([updatedAt])
  @@index([status])
}

// ── Symptom (PR-02) ────────────────────────────────────────────────────────────

model Symptom {
  id           String           @id @default(uuid())
  code         String           @unique
  nameUz       String
  nameRu       String?
  nameEn       String?
  nameLat      String?
  category     String
  bodyZone     String?
  severity     SymptomSeverity  @default(MILD)
  synonyms     String[]         @default([])
  isRedFlag    Boolean          @default(false)
  // ── FTS (PR-06) ────────────────────────────────────────────────────────
  searchVector Unsupported("tsvector")?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  diseaseLinks DiseaseSymptom[]

  @@index([category])
  @@index([bodyZone])
}

// ── DiseaseSymptom M2M (PR-02) ─────────────────────────────────────────────────

model DiseaseSymptom {
  id           String   @id @default(uuid())
  diseaseId    String
  symptomId    String
  weight       Decimal  @db.Decimal(5, 3) @default(1.000)
  specificity  Decimal? @db.Decimal(5, 3)
  sensitivity  Decimal? @db.Decimal(5, 3)
  isRequired   Boolean  @default(false)
  isExcluding  Boolean  @default(false)
  createdAt    DateTime @default(now())

  disease      Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  symptom      Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, symptomId])
  @@index([diseaseId])
  @@index([symptomId])
}

// ── Reference (PR-02) ──────────────────────────────────────────────────────────

model Reference {
  id             String         @id @default(uuid())
  type           ReferenceType
  citation       String         @db.Text
  url            String?
  doi            String?        @unique
  pubmedId       String?
  whoCode        String?
  publishedAt    DateTime?
  accessedAt     DateTime       @default(now())
  evidenceLevel  EvidenceLevel  @default(C)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  diseases       DiseaseReference[]
  epidemiology   RegionEpidemiology[]

  @@index([type])
  @@index([pubmedId])
}

// ── DiseaseReference M2M (PR-02) ───────────────────────────────────────────────

model DiseaseReference {
  id            String    @id @default(uuid())
  diseaseId     String
  referenceId   String
  blockMarker   String?
  note          String?   @db.Text
  createdAt     DateTime  @default(now())

  disease       Disease   @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  reference     Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, referenceId, blockMarker])
  @@index([diseaseId])
  @@index([referenceId])
}

// ── DiseaseBlock (PR-03) ───────────────────────────────────────────────────────

model DiseaseBlock {
  id                 String            @id @default(uuid())
  diseaseId          String
  marker             String            // canonical id: "etiology", "pathogenesis", ...
  label              String            // display label (synonym variant)
  level              ContentLevel      @default(L1)
  orderIndex         Int               @default(0)
  audiencePriority   Json?             // { patient: 1, doctor: 2, ... }
  contentMd          String            @db.Text
  contentJson        Json?
  translationStatusUz TranslationStatus @default(VERIFIED)
  translationStatusRu TranslationStatus @default(PENDING)
  translationStatusEn TranslationStatus @default(PENDING)
  evidenceLevel      EvidenceLevel     @default(C)
  status             ApprovalStatus    @default(DRAFT)
  lastEditedBy       Int?
  lastEditedAt       DateTime?
  publishedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  disease            Disease           @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  editLogs           DiseaseEditLog[]

  @@index([diseaseId])
  @@index([marker])
  @@index([status])
  @@unique([diseaseId, marker])
}

// ── DiseaseStage (PR-03) ───────────────────────────────────────────────────────

model DiseaseStage {
  id              String     @id @default(uuid())
  diseaseId       String
  stageType       StageType
  orderIndex      Int        @default(0)
  titleUz         String
  descriptionMd   String     @db.Text
  imageKey        String?
  clinicalSigns   String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  disease         Disease    @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@index([stageType])
}

// ── DiseaseMedication (PR-03) ──────────────────────────────────────────────────

model DiseaseMedication {
  id                 String                @id @default(uuid())
  diseaseId          String
  medicineId         String
  group              String                // e.g. "NSAID", "DMARD"
  averageDose        String
  dosageNotes        String?               @db.Text
  contraindications  String?               @db.Text
  interactions       Json?
  evidenceLevel      EvidenceLevel         @default(C)
  audienceVisibility MedicationVisibility  @default(DOCTOR)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  disease            Disease               @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  medicine           Medicine              @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@index([diseaseId])
  @@index([medicineId])
  @@unique([diseaseId, medicineId, group])
}

// ── DiseaseLabTest (PR-03) ─────────────────────────────────────────────────────
// NOTE: Intentionally NOT FK'd to LabTest. Existing LabTest belongs to a per-
// patient LabOrder (lab order item). DiseaseLabTest is a dictionary reference
// (which test to run for a disease). Loose reference via LOINC / local code.
// See plan §3 PR-03 and project context note 7.2.

model DiseaseLabTest {
  id              String           @id @default(uuid())
  diseaseId       String
  labTestCode     String           // LOINC or local code
  name            String
  loincCode       String?
  priority        LabTestPriority  @default(MINIMUM)
  fastingRequired Boolean          @default(false)
  timingNotes     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  disease         Disease          @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@index([labTestCode])
  @@unique([diseaseId, labTestCode])
}

// ── ClinicalCase (PR-03) ───────────────────────────────────────────────────────

model ClinicalCase {
  id                 String   @id @default(uuid())
  diseaseId          String
  anonymousId        String
  ageRange           String
  gender             Gender
  anamnesisMd        String   @db.Text
  diagnosisResultMd  String   @db.Text
  treatmentMd        String   @db.Text
  outcomeMd          String   @db.Text
  publishedBy        Int?
  publishedAt        DateTime?
  consentObtained    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  disease            Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  publisher          User?    @relation("ClinicalCasePublisher", fields: [publishedBy], references: [id], onDelete: SetNull)

  @@index([diseaseId])
  @@index([publishedBy])
}

// ── UserDiseaseNote (PR-04) ────────────────────────────────────────────────────

model UserDiseaseNote {
  id             String   @id @default(uuid())
  userId         Int
  diseaseId      String
  noteMd         String?  @db.Text
  symptomAnswers Json?
  savedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease        Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([diseaseId])
  @@unique([userId, diseaseId])
}

// ── AITriageSession (PR-04) ────────────────────────────────────────────────────

model AITriageSession {
  id            String   @id @default(uuid())
  userId        Int?
  anonymousId   String?
  symptoms      Json
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  matchSessions SymptomMatchSession[]

  @@index([userId])
  @@index([anonymousId])
  @@index([expiresAt])
}

// ── SymptomMatchSession (PR-04) ────────────────────────────────────────────────

model SymptomMatchSession {
  id                 String              @id @default(uuid())
  userId             Int?
  anonymousId        String?
  aiTriageSessionId  String?
  diseaseId          String
  matchScore         Decimal             @db.Decimal(5, 3) @default(0.000)
  matchedSymptoms    Json
  missingSymptoms    Json
  userAnswers        Json
  status             MatchSessionStatus  @default(ACTIVE)
  sentToDoctorId     Int?
  doctorNote         String?
  doctorRespondedAt  DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  expiresAt          DateTime

  user               User?               @relation("MatchSessionUser", fields: [userId], references: [id], onDelete: SetNull)
  doctor             User?               @relation("MatchSessionDoctor", fields: [sentToDoctorId], references: [id], onDelete: SetNull)
  disease            Disease             @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  aiTriageSession    AITriageSession?    @relation(fields: [aiTriageSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([diseaseId])
  @@index([status])
  @@index([expiresAt])
}

// ── DiseaseEditLog (PR-04) ─────────────────────────────────────────────────────

model DiseaseEditLog {
  id         String       @id @default(uuid())
  diseaseId  String
  blockId    String?
  editorId   Int
  editType   EditLogType
  diffJson   Json
  createdAt  DateTime     @default(now())

  disease    Disease      @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  block      DiseaseBlock? @relation(fields: [blockId], references: [id], onDelete: SetNull)
  editor     User         @relation("DiseaseEditor", fields: [editorId], references: [id], onDelete: Restrict)

  @@index([diseaseId])
  @@index([blockId])
  @@index([editorId])
  @@index([createdAt])
}

// ── RegionEpidemiology (PR-04) ─────────────────────────────────────────────────

model RegionEpidemiology {
  id           String     @id @default(uuid())
  diseaseId    String
  region       String     // "UZ", "UZ-TO", "global"
  prevalence   Decimal?   @db.Decimal(10, 6)
  incidence    Decimal?   @db.Decimal(10, 6)
  mortality    Decimal?   @db.Decimal(10, 6)
  sourceRefId  String?
  period       String     // e.g. "2023"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  disease      Disease    @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  sourceRef    Reference? @relation(fields: [sourceRefId], references: [id], onDelete: SetNull)

  @@index([diseaseId])
  @@index([region])
  @@unique([diseaseId, region, period])
}

// ── DiseaseSpecialty M2M (PR-04) ───────────────────────────────────────────────

model DiseaseSpecialty {
  id              String        @id @default(uuid())
  doctorProfileId String
  diseaseId       String
  createdAt       DateTime      @default(now())

  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  disease         Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, diseaseId])
  @@index([doctorProfileId])
  @@index([diseaseId])
}

// ── Disease KB v2 extensions (scientists, research, genetics) ──────────────────

model DiseaseScientist {
  id              String        @id @default(uuid())
  diseaseId       String
  fullName        String
  role            ScientistRole
  country         String?
  birthYear       Int?
  deathYear       Int?
  bioMd           String?       @db.Text
  contributionsMd String?       @db.Text
  photoUrl        String?
  orderIndex      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  disease         Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@index([role])
}

model DiseaseResearch {
  id            String        @id @default(uuid())
  diseaseId     String
  title         String
  authors       String
  journal       String?
  year          Int
  doi           String?
  pubmedId      String?
  nctId         String?
  type          ResearchType
  summaryMd     String        @db.Text
  evidenceLevel EvidenceLevel @default(C)
  isLandmark    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  disease       Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, doi])
  @@index([diseaseId])
  @@index([year])
  @@index([type])
}

model DiseaseGenetic {
  id                 String              @id @default(uuid())
  diseaseId          String
  geneSymbol         String?
  variantType        String?
  inheritancePattern InheritancePattern?
  penetrance         Decimal?            @db.Decimal(4, 3)
  bloodGroupRisk     BloodGroup?
  populationNoteMd   String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  disease            Disease             @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@index([geneSymbol])
}

// ── Real-time Chat (Socket.io) ────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String   // "consultation_{id}" | "visit_{id}" | "direct_{userId1}_{userId2}"
  senderId  Int
  sender    User     @relation("ChatSentMessages", fields: [senderId], references: [id])
  content   String   @db.Text
  type      String   @default("TEXT") // TEXT | TRIAGE_RESULT | FILE
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
}

// ─── Triage catalogue (GAP-04/05, frontend-parity) ───────────────────────────
// These three models persist the clinical catalogue that the frontend
// currently ships as TypeScript constants (`src/app/lib/red-flag-engine.ts`,
// `src/app/calculators/*`). Goal: let medical editors update rules/formulas
// without a redeploy. Bootstrap seed lives in
// `server/prisma/seeds/triage-catalogue.ts` and mirrors the FE constants.

enum EmergencySeverity {
  CRITICAL
  HIGH
  MODERATE
}

enum CalculatorInputType {
  NUMBER
  BOOLEAN
  SELECT
}

/// Universal klinik asbob toifasi (GAP-05d). Har toifa o'z hisoblash va
/// UI render strategiyasi bilan keladi:
///   SCORE         — raqamli risk skoreri (CHA₂DS₂-VASc, HEART, Wells)
///   QUESTIONNAIRE — bemor-hisoboti (PHQ-9, GAD-7, CAT, ACT, AUDIT)
///   CRITERIA      — boolean diagnostic tree (Light's, Duke, ACR)
///   DOSE          — dori-doza hisobi (DOCTOR-only audience majburiy)
///   STAGING       — kasallik bosqichi klassifikatsiyasi (NYHA, MELD, Child-Pugh)
enum ClinicalToolType {
  SCORE
  QUESTIONNAIRE
  CRITERIA
  DOSE
  STAGING
}

/// RedFlagRule — persistent red-flag rule catalogue.
///
/// Scope fields (`applicableCategories`, `applicableIcd10Prefixes`) mirror
/// the frontend `RedFlagRule` interface exactly — both layers agree that
/// BOTH filters must match when set (AND semantics), and an unset field
/// means "open". The boolean decision tree lives in `conditionJson` as a
/// `RuleCondition` tree; the server never re-evaluates it (compute stays
/// on the client so alerts render in <50 ms), the DB is source-of-truth.
model RedFlagRule {
  id                       String              @id @default(uuid())
  /// Stable slug matching frontend constants (e.g. 'rule.hypertensive-crisis').
  ruleKey                  String              @unique
  /// i18n key for the human-readable name shown in the banner.
  nameKey                  String
  /// i18n key for the action/CTA message ('emergency.critical.action', …).
  actionKey                String
  severity                 EmergencySeverity
  applicableCategories     String[]            @default([])
  applicableIcd10Prefixes  String[]            @default([])
  /// `RuleCondition` tree (kind: 'symptom' | 'and' | 'or').
  conditionJson            Json
  /// Editorial notes / citation; surfaced in the admin UI only.
  sourceCitation           String?             @db.Text
  isActive                 Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  events                   RedFlagEvent[]

  @@index([severity])
  @@index([isActive])
}

/// ClinicalTool — universal klinik asbob katalogi (GAP-05d).
///
/// Bir model 5 xil asbob turini boshqaradi (`toolType`): SCORE,
/// QUESTIONNAIRE, CRITERIA, DOSE, STAGING. Avvalgi `ClinicalCalculator`
/// ham shu yerga birlashtiriladi (`toolType = SCORE`).
///
/// Admin boshqaruvi layerlari:
///   1. `isActive` — global on/off (tizim admin qo'li)
///   2. `allowedAudiences` — qaysi foydalanuvchi roli ko'rishi mumkin
///      (bo'sh bo'lsa = hamma authenticated)
///   3. `requiredRoles` — QAT'IY gate: faqat shu rollar ishlata oladi
///      (masalan, DOSE toolType majburiy `DOCTOR` bo'ladi)
///   4. `applicableCategories` + `applicableIcd10Prefixes` — kasallik
///      scope (AND semantikasi, bo'sh = GLOBAL)
///   5. `clinicOverridesJson` — har-klinika darajada override JSON
///      `{ "<clinicId>": { "isActive": false, "reason": "..." } }`
///
/// `formulaKey` — whitelist identifier (FE compute function nomi), DB'da
/// hech qanday arbitrary kod saqlanmaydi. Formula o'zgarishi engineering
/// PR + code review talab qiladi; editor faqat meta-ma'lumot + scope +
/// activation'ni boshqaradi.
model ClinicalTool {
  id                       String              @id @default(uuid())
  /// Stable slug mos keladi FE registriga (e.g. 'chads-vasc', 'phq-9').
  toolKey                  String              @unique
  toolType                 ClinicalToolType

  // ── i18n + tavsif ────────────────────────────────────────────────────
  /// i18n key for the tool name ("calc.chadsVasc.name", "tool.phq9.name").
  nameKey                  String
  /// i18n key for 1-2 sentence intro shown above the inputs.
  descriptionKey           String?
  /// Citation text ("ESC 2020 AF Guidelines", "Kroenke 2001").
  source                   String
  /// Optional DOI / URL to primary literature or guideline.
  sourceUrl                String?
  evidenceLevel            EvidenceLevel       @default(C)

  // ── Formula (trust boundary) ──────────────────────────────────────────
  /// Whitelisted compute function identifier on the client.
  formulaKey               String
  /// `CalculatorInput[]` or `QuestionnaireItem[]` — shape depends on toolType.
  inputsJson               Json
  /// Optional output schema (band thresholds, recommendation map).
  outputSchemaJson         Json?
  /// Fine-grained — which audience sees the formula text ('L2' | 'L3').
  showFormulaForAudience   String?

  // ── Kasallik bo'yicha scope ─────────────────────────────────────────
  applicableCategories     String[]            @default([])
  applicableIcd10Prefixes  String[]            @default([])

  // ── Foydalanuvchi rol-boshqaruvi ─────────────────────────────────────
  /// Kimning UI'da ko'rishi mumkinligini cheklaydi. Bo'sh = barcha
  /// authenticated foydalanuvchilar. DOSE toolType odatda faqat
  /// [DOCTOR, SPECIALIST, NURSE] bilan cheklanadi.
  allowedAudiences         AudienceMode[]      @default([])
  /// HARD gate: faqat shu rollar API ga muvaffaqiyatli "run" so'rovi
  /// yubora oladi. Audience'dan ko'ra qattiqroq (backend 403 qaytaradi).
  /// DOSE toolType uchun majburiy to'ldiriladi (DOCTOR / SPECIALIST).
  requiredRoles            UserRole[]          @default([])

  // ── Activation + admin audit ─────────────────────────────────────────
  isActive                 Boolean             @default(true)
  /// Deaktivatsiya sababi (ADMIN UI'da ko'rinadi, foydalanuvchi ko'rmaydi).
  deactivationReason       String?             @db.Text
  deactivatedAt            DateTime?
  deactivatedBy            Int?
  /// Per-klinika override map. Format:
  /// { "<clinicId>": { "isActive": false, "reason": "...", "updatedAt": "..." } }
  /// Klinika administratori faqat o'z klinikasi uchun yopishi mumkin.
  clinicOverridesJson      Json?

  // ── Locale + UI ──────────────────────────────────────────────────────
  /// O'zbek populyatsiyasiga moslik: 'HIGH' | 'MEDIUM' | 'LOW'. LOW
  /// bo'lsa FE disclaimer banner ko'rsatadi.
  regionFitness            String?
  /// UI ordering. Kichik qiymat = yuqoriroq prioritet (default 100).
  priorityWeight           Int                 @default(100)

  // ── Audit ────────────────────────────────────────────────────────────
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  createdBy                Int?
  updatedBy                Int?

  usageLogs                ClinicalToolUsageLog[]

  @@index([toolType])
  @@index([formulaKey])
  @@index([isActive])
  @@index([priorityWeight])
}

/// RedFlagEvent — immutable audit log of rule hits. Written every time a
/// user's answer set triggers a rule in `SymptomMatchSession`. Critical
/// for retrospective clinical review and for evaluating over-/under-
/// triage rates.
///
/// Intentionally decoupled from `SymptomMatchSession` via `SetNull` so we
/// can retain audit trail after a session expires/archives (HIPAA-style
/// audit persistence, though we do not hold PHI per CLAUDE.md MVP rules).
model RedFlagEvent {
  id                String               @id @default(uuid())
  ruleId            String
  matchSessionId    String?
  /// Symptom codes that resolved true (denormalised from the hit).
  triggeredBy       String[]             @default([])
  severityAtFire    EmergencySeverity
  /// Set if the client surfaced the banner to the user.
  shownToUser       Boolean              @default(true)
  createdAt         DateTime             @default(now())

  rule              RedFlagRule          @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@index([ruleId])
  @@index([matchSessionId])
  @@index([createdAt])
  @@index([severityAtFire])
}

/// ClinicalToolUsageLog — lightweight adoption tracking. Records WHICH
/// tool was used against WHICH disease at what result band, without
/// storing the input values (those are PHI-adjacent).
///
/// `toolType` denormalized so analytics queries can group by toolType
/// without a JOIN. Numeric vs boolean vs band result stored in three
/// nullable columns — the correct column depends on toolType:
///   SCORE / DOSE      → `numericValue` + `band` (optional)
///   QUESTIONNAIRE     → `numericValue` (total) + `band`
///   CRITERIA          → `booleanValue`
///   STAGING           → `band` (NYHA I-IV, MELD band, …)
model ClinicalToolUsageLog {
  id              String              @id @default(uuid())
  toolId          String
  /// Denormalized for analytics; mirrors `tool.toolType`.
  toolType        ClinicalToolType
  diseaseId       String?
  matchSessionId  String?
  /// Klinika tenant ID (agar foydalanuvchi klinika ichida ishlayotgan bo'lsa).
  clinicId        Int?
  /// Shu asbobni ishga tushirgan foydalanuvchi roli — rol-level adoption
  /// ko'rsatkichlarini olish uchun denormalize qilindi.
  invokedByRole   UserRole?
  /// Band stored as string to stay in sync with FE `ToolResult['band']`
  /// ('low' | 'moderate' | 'high' | 'very_high' | 'nyha-i' | …).
  band            String?
  /// SCORE / QUESTIONNAIRE / DOSE numeric result (rounded).
  numericValue    Decimal?            @db.Decimal(12, 3)
  /// CRITERIA boolean outcome (true = positive / meets criteria).
  booleanValue    Boolean?
  createdAt       DateTime            @default(now())

  tool            ClinicalTool        @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([toolType])
  @@index([diseaseId])
  @@index([matchSessionId])
  @@index([clinicId])
  @@index([createdAt])
}
