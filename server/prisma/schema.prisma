generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PATIENT
  RADIOLOG
  DOCTOR
  SPECIALIST
  OPERATOR
  ADMIN
  KASSIR
}

enum Gender {
  MALE
  FEMALE
}

enum Language {
  UZ
  RU
}

enum AppStatus {
  NEW
  PAID_PENDING
  ACCEPTED
  EXTRA_INFO_NEEDED
  WITH_SPECIALIST
  CONCLUSION_WRITING
  DONE
  FAILED
  ARCHIVED
  HV_ONWAY
  HV_ARRIVED
}

enum ServiceType {
  AI_RADIOLOG
  RADIOLOG_ONLY
  RADIOLOG_SPECIALIST
  CONSULTATION
  HOME_VISIT
}

enum Urgency {
  NORMAL
  URGENT
  EMERGENCY
}

enum PaymentProvider {
  PERSONAL_CARD
  PAYME
  CLICK
  UZUM
  UZCARD
  HUMO
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ConclusionType {
  AI_ANALYSIS
  RADIOLOG
  SPECIALIST
  DOCTOR
}

enum FileType {
  DICOM
  IMAGE
  PDF
  OTHER
}

enum KassaTolovUsuli {
  NAQD
  KARTA
  PAYME
  CLICK
  UZUM
  UZCARD
  HUMO
  TERMINAL
}

enum KassaTolovHolati {
  KUTILMOQDA
  QABUL_QILINDI
  BEKOR
  QAYTARILDI
}

enum SmenaHolati {
  OCHIQ
  YOPIQ
}

enum TariffCode {
  FREE
  START
  LITE
  PREMIUM
}

enum OperationComplexity {
  SIMPLE
  MEDIUM
  COMPLEX
  VERY_COMPLEX
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ── Auth Models ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  telegramId       BigInt?   @unique
  username         String?
  phone            String    @unique
  pin              String?
  fullName         String
  role             UserRole
  gender           Gender?
  birthDate        String?
  city             String?
  chronicDiseases  String?
  language         Language  @default(UZ)
  isActive         Boolean   @default(true)
  avatar           String?
  license          String?
  specialty        String?
  experience       Int?
  rating           Float?
  totalConclusions   Int?               @default(0)
  isOnline           Boolean            @default(false)
  lastSeenAt         DateTime?
  profileUrl         String?            @unique
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())

  // Relations
  patientApps      Application[] @relation("PatientApps")
  radiologApps     Application[] @relation("RadiologApps")
  specialistApps   Application[] @relation("SpecialistApps")
  doctorApps       Application[] @relation("DoctorApps")
  conclusions      Conclusion[]
  notifications    Notification[]
  kassaSmenas      KassaSmena[]
  kassaTolovlar    KassaTolov[]  @relation("KassirTolov")
  auditEvents      AuditEvent[]
  doctorProfile    DoctorProfile?
  contactRequests  ContactRequest[] @relation("PatientContacts")
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  messagePermissions   MessagePermission[]    @relation("PatientPermissions")
  consultationRequests ConsultationRequest[]  @relation("PatientConsultations")
  refreshTokens        RefreshToken[]

  // Lab, Pharmacy, EMR relations
  patientLabOrders     LabOrder[]         @relation("PatientLabOrders")
  doctorLabOrders      LabOrder[]         @relation("DoctorLabOrders")
  patientPrescriptions Prescription[]     @relation("PatientPrescriptions")
  doctorPrescriptions  Prescription[]     @relation("DoctorPrescriptions")
  patientRecords       MedicalRecord[]    @relation("PatientMedicalRecords")
  doctorRecords        MedicalRecord[]    @relation("DoctorMedicalRecords")
  allergies            Allergy[]          @relation("PatientAllergies")

  @@index([role])
  @@index([phone])
}

model Application {
  id              Int         @id @default(autoincrement())
  arizaNumber     String      @unique
  patientId       Int
  radiologId      Int?
  specialistId    Int?
  doctorId        Int?
  status          AppStatus   @default(NEW)
  serviceType     ServiceType
  urgency         Urgency     @default(NORMAL)
  scanType        String?
  organ           String?
  scanDate        String?
  scanFacility    String?
  price           Decimal     @db.Decimal(12, 2)
  notes           String?
  rating          Int?
  ratingComment   String?
  deadlineAt      DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Uyga chaqirish
  hvClinicName       String?
  hvDoctorName       String?
  hvDoctorSpeciality String?
  hvVisitDay         String?
  hvTimeSlot         String?
  hvAddress          String?

  // Relations
  patient         User         @relation("PatientApps", fields: [patientId], references: [id])
  radiolog        User?        @relation("RadiologApps", fields: [radiologId], references: [id])
  specialist      User?        @relation("SpecialistApps", fields: [specialistId], references: [id])
  doctor          User?        @relation("DoctorApps", fields: [doctorId], references: [id])
  anamnez         Anamnez?
  files           FileRecord[]
  payment         Payment?
  conclusions     Conclusion[]
  auditLog        AuditEvent[]
  examinations    Examination[]
  kassaTolovlar   KassaTolov[]
  labOrders       LabOrder[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]

  @@index([patientId])
  @@index([status])
  @@index([radiologId])
  @@index([createdAt])
}

model Anamnez {
  id                Int         @id @default(autoincrement())
  applicationId     Int         @unique
  complaint         String
  duration          String?
  hasPain           Boolean     @default(false)
  painLevel         Int?
  previousTreatment String?
  medications       String?
  allergies         String?
  additionalInfo    String?

  application       Application @relation(fields: [applicationId], references: [id])
}

model FileRecord {
  id              Int         @id @default(autoincrement())
  applicationId   Int
  fileType        FileType
  originalName    String
  s3Key           String
  sizeBytes       BigInt
  mimeType        String
  preview         String?
  uploadedAt      DateTime    @default(now())

  application     Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model Payment {
  id                    Int            @id @default(autoincrement())
  applicationId         Int            @unique
  amount                Decimal        @db.Decimal(12, 2)
  provider              PaymentProvider
  providerTransactionId String?
  status                PaymentStatus  @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime       @default(now())

  application           Application    @relation(fields: [applicationId], references: [id])
}

model Conclusion {
  id              Int            @id @default(autoincrement())
  applicationId   Int
  authorId        Int
  conclusionType  ConclusionType
  description     String
  findings        String
  impression      String
  recommendations String?
  source          String?
  aiAnalysis      Json?
  pdfUrl          String?
  signedAt        DateTime       @default(now())

  application     Application    @relation(fields: [applicationId], references: [id])
  author          User           @relation(fields: [authorId], references: [id])

  @@index([applicationId])
}

model AuditEvent {
  id              Int       @id @default(autoincrement())
  applicationId   Int
  action          String
  actorId         Int?
  actorRole       String?
  actorName       String?
  details         Json?
  createdAt       DateTime  @default(now())

  application     Application @relation(fields: [applicationId], references: [id])
  actor           User?       @relation(fields: [actorId], references: [id])

  @@index([applicationId])
}

model Notification {
  id              Int       @id @default(autoincrement())
  userId          Int
  title           String
  message         String
  type            String    @default("info")
  isRead          Boolean   @default(false)
  applicationId   Int?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Examination {
  id               Int       @id @default(autoincrement())
  applicationId    Int
  category         String
  instrumentalType String?
  labTypes         String[]
  organ            String?
  dateStatus       String    @default("unknown")
  dateYmd          String?
  approxYear       String?
  facility         String?
  createdAt        DateTime  @default(now())

  application      Application @relation(fields: [applicationId], references: [id])
}

model KassaSmena {
  id               Int         @id @default(autoincrement())
  kassirId         Int
  kassirIsmi       String
  ochilganVaqt     DateTime    @default(now())
  yopilganVaqt     DateTime?
  boshlanghichQoldiq Decimal   @db.Decimal(12, 2) @default(0)
  naqd             Decimal     @db.Decimal(12, 2) @default(0)
  karta            Decimal     @db.Decimal(12, 2) @default(0)
  onlayn           Decimal     @db.Decimal(12, 2) @default(0)
  jami             Decimal     @db.Decimal(12, 2) @default(0)
  tolovlarSoni     Int         @default(0)
  holati           SmenaHolati @default(OCHIQ)

  kassir           User        @relation(fields: [kassirId], references: [id])
  tolovlar         KassaTolov[]

  @@index([kassirId])
}

model KassaTolov {
  id              Int              @id @default(autoincrement())
  smenaId         Int
  applicationId   Int
  invoiceRaqam    String           @unique
  bemorIsmi       String
  xizmatNomi      String
  summa           Decimal          @db.Decimal(12, 2)
  chegirma        Decimal          @db.Decimal(12, 2) @default(0)
  tolashKerak     Decimal          @db.Decimal(12, 2)
  tolanganSumma   Decimal          @db.Decimal(12, 2)
  qaytim          Decimal          @db.Decimal(12, 2) @default(0)
  tolovUsuli      KassaTolovUsuli
  holati          KassaTolovHolati @default(KUTILMOQDA)
  kassirId        Int
  izoh            String?
  sanaVaqt        DateTime         @default(now())

  smena           KassaSmena       @relation(fields: [smenaId], references: [id])
  application     Application      @relation(fields: [applicationId], references: [id])
  kassir          User             @relation("KassirTolov", fields: [kassirId], references: [id])
}

// ── Statik ma'lumotlar uchun jadvallar ───────────────────────────────────────

model ExaminationCenter {
  id          Int    @id @default(autoincrement())
  name        String
  region      String
  district    String
  rating      Float  @default(0)
  price       Int    @default(0)
  distanceKm  Float  @default(0)

  @@index([region, district])
}

model BookingSlot {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      String
  time      String
  status    String   @default("free")

  @@unique([doctorId, date, time])
}

// ── TZ-01: Shifokor Profili va Tarif Tizimi ──────────────────────────────────

model Tariff {
  id          String         @id @default(uuid())
  name        String
  code        TariffCode     @unique
  price       Int            @default(0)
  features    Json
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  description String?
  doctors     DoctorProfile[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Clinic {
  id            String         @id @default(uuid())
  name          String
  address       String
  city          String?
  region        String?
  phone         String?
  email         String?
  website       String?
  isVerified    Boolean        @default(false)
  verifiedBy    Int?
  latitude      Float?
  longitude     Float?
  servicesCount Int            @default(0)
  isTop         Boolean        @default(false)
  topPriority   Int            @default(0)
  topExpiresAt  DateTime?
  logoUrl       String?
  rating        Float          @default(0)
  description   String?
  doctors       DoctorClinic[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DoctorProfile {
  id                    String   @id @default(uuid())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id])

  bio                   String?  @db.Text
  birthDate             DateTime?
  experienceYears       Int      @default(0)
  subSpecialties        String[] @default([])
  qualificationCategory String?
  qualificationDocUrl   String?
  licenseNumber         String?
  licenseDocUrl         String?
  licenseVerified       Boolean  @default(false)
  qualificationVerified Boolean  @default(false)
  socialLinks           Json?
  profileUrl            String?  @unique
  isPublic              Boolean  @default(true)
  isBusinessAccount     Boolean  @default(false)

  tariffId              String?
  tariff                Tariff?  @relation(fields: [tariffId], references: [id])

  clinics               DoctorClinic[]
  operationTypes        DoctorOperationType[]
  education             Education[]
  workExperience        WorkExperience[]
  achievements          Achievement[]
  certificates          Certificate[]
  contactRequests       ContactRequest[]
  messageTemplates      MessageTemplate[]
  messagePermissions    MessagePermission[] @relation("DoctorPermissions")
  faq                   FAQ[]
  medicalServices       MedicalService[]
  anonymousNumber       AnonymousNumber?
  callSchedule          CallSchedule?
  telegramBotConfig     TelegramBotConfig?
  adSetting             AdSetting?
  calendarSetting       CalendarSetting?
  calendarSlots         CalendarSlot[]
  consultationRequests  ConsultationRequest[] @relation("DoctorConsultations")

  totalConsultations    Int   @default(0)
  totalOperations       Int   @default(0)
  onlineConsultations   Int   @default(0)
  offlineConsultations  Int   @default(0)
  averageRating         Float @default(0)
  totalRatings          Int   @default(0)
  overallRank           Int?
  specialtyRank         Int?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DoctorClinic {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  clinicId   String
  clinic     Clinic        @relation(fields: [clinicId], references: [id])
  position   String?
  department String?
  cabinet    String?
  floor      Int?
  isVerified Boolean       @default(false)
  verifiedBy Int?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())

  @@unique([doctorId, clinicId])
}

model DoctorOperationType {
  id              String              @id @default(uuid())
  doctorId        String
  doctor          DoctorProfile       @relation(fields: [doctorId], references: [id])
  operationCode   String
  operationName   String
  operationNameRu String?
  category        String
  complexity      OperationComplexity @default(MEDIUM)
  avgDurationMin  Int?
  description     String?
  count           Int                 @default(0)
  createdAt       DateTime            @default(now())

  @@unique([doctorId, operationCode])
}

// ── TZ-02: Professional Portfolio ───────────────────────────────────────────

model Education {
  id              String        @id @default(uuid())
  doctorId        String
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id])
  institutionName String
  faculty         String?
  degree          String        // BACHELOR, MASTER, PHD, DSC, RESIDENCY, ORDINATURA
  startYear       Int
  endYear         Int?
  diplomaNumber   String?
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([doctorId])
}

model WorkExperience {
  id               String        @id @default(uuid())
  doctorId         String
  doctor           DoctorProfile @relation(fields: [doctorId], references: [id])
  organizationName String
  position         String
  department       String?
  startYear        Int
  endYear          Int?          // null = hozir ishlaydi
  description      String?
  createdAt        DateTime      @default(now())

  @@index([doctorId])
}

model Achievement {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  name        String
  nameRu      String?
  group       String        // SCIENTIFIC, PRACTICAL, ORGANIZATIONAL, INTERNATIONAL, STATE
  year        Int
  description String?
  documentUrl String?
  stickerType String?       // GOLD, SILVER, BRONZE, SPECIAL
  isVerified  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([doctorId])
}

model Certificate {
  id             String        @id @default(uuid())
  doctorId       String
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  name           String
  nameRu         String?
  organization   String
  direction      String
  year           Int
  certificateNum String?
  documentUrl    String?
  expiresAt      DateTime?
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([doctorId])
}

// ── TZ-04: Ariza Qoldirish va Aloqa ────────────────────────────────────────

model ContactRequest {
  id            String        @id @default(uuid())
  doctorId      String
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  patientId     Int?
  patient       User?         @relation("PatientContacts", fields: [patientId], references: [id])
  patientName   String
  patientPhone  String
  patientEmail  String?
  requestType   String        // CONSULTATION, COMPLAINT, FOLLOW_UP, OTHER
  message       String        @db.Text
  templateUsed  String?
  status        String        @default("NEW") // NEW, READ, REPLIED, ARCHIVED
  doctorReply   String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([doctorId])
  @@index([status])
}

model MessageTemplate {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  category   String        // COMPLAINT, SYMPTOM, FOLLOW_UP
  title      String
  content    String        @db.Text
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  usageCount Int           @default(0)
  createdAt  DateTime      @default(now())

  @@index([doctorId])
}

// ── TZ-05: Xabar Yuborish Tizimi ───────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    Int
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  Int
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String?  @db.Text
  messageType String   @default("TEXT") // TEXT, IMAGE, FILE, VOICE
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  consultId   String?
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model MessagePermission {
  id              String        @id @default(uuid())
  patientId       Int
  patient         User          @relation("PatientPermissions", fields: [patientId], references: [id])
  doctorId        String
  doctor          DoctorProfile @relation("DoctorPermissions", fields: [doctorId], references: [id])
  consultationId  String?
  grantedBy       String        // AUTO, DOCTOR
  status          String        @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, REQUESTED
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([patientId, doctorId])
}

// ── TZ-06: FAQ va Tibbiy Xizmatlar ─────────────────────────────────────────

model FAQ {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  question   String
  questionRu String?
  answer     String        @db.Text
  answerRu   String?       @db.Text
  category   String        // OPERATION, RECOVERY, COSTS, CONSULTATION, DIAGNOSTICS
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  viewCount  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([doctorId])
}

model MedicalService {
  id             String        @id @default(uuid())
  doctorId       String
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  name           String
  nameRu         String?
  category       String        // INSTRUMENTAL, LABORATORY, OPERATION, CONSULTATION, DIAGNOSTICS
  price          Int?
  priceFrom      Int?
  priceTo        Int?
  description    String?       @db.Text
  descriptionRu  String?       @db.Text
  targetAudience String?
  preparation    String?
  duration       String?
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([doctorId])
}

// ── TZ-07: Qo'shimcha Funksionallar ────────────────────────────────────────

model AnonymousNumber {
  id            String        @id @default(uuid())
  doctorId      String        @unique
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  virtualNumber String?
  realNumber    String?
  provider      String?       // TWILIO, LOCAL_SIP
  isActive      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CallSchedule {
  id         String        @id @default(uuid())
  doctorId   String        @unique
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  workDays   Int[]         @default([1, 2, 3, 4, 5])
  startTime  String        @default("09:00")
  endTime    String        @default("18:00")
  lunchStart String?       @default("13:00")
  lunchEnd   String?       @default("14:00")
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model TelegramBotConfig {
  id         String        @id @default(uuid())
  doctorId   String        @unique
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  botToken   String?
  channelId  String?
  channelUrl String?
  isOwnBot   Boolean       @default(false)
  autoPost   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model AdSetting {
  id            String        @id @default(uuid())
  doctorId      String        @unique
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id])
  showBannerAds Boolean       @default(true)
  showPopupAds  Boolean       @default(true)
  showInFeedAds Boolean       @default(true)
  adFrequency   String        @default("NORMAL") // NONE, MINIMAL, NORMAL, FULL
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ── TZ-03: Kalendar va Konsultatsiya ────────────────────────────────────────

model CalendarSetting {
  id             String        @id @default(uuid())
  doctorId       String        @unique
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id])
  workDays       Int[]         @default([1, 2, 3, 4, 5])
  startTime      String        @default("09:00")
  endTime        String        @default("18:00")
  slotDuration   Int           @default(30)
  breakDuration  Int           @default(10)
  consultTypes   String[]      @default(["OFFLINE", "ONLINE"])
  onlinePrice    Int           @default(0)
  offlinePrice   Int           @default(0)
  phonePrice     Int           @default(0)
  videoPrice     Int           @default(0)
  maxPatientsDay Int           @default(20)
  officeAddress  String?
  officeName     String?
  officeFloor    Int?
  officeCabinet  String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model CalendarSlot {
  id           String              @id @default(uuid())
  doctorId     String
  doctor       DoctorProfile       @relation(fields: [doctorId], references: [id])
  date         DateTime
  startTime    String
  endTime      String
  status       String              @default("FREE") // FREE, BOOKED, BLOCKED, CANCELLED
  blockedBy    String?
  blockReason  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  consultation ConsultationRequest?

  @@index([doctorId, date])
  @@index([status])
}

model ConsultationRequest {
  id            String        @id @default(uuid())
  patientId     Int
  patient       User          @relation("PatientConsultations", fields: [patientId], references: [id])
  doctorId      String
  doctor        DoctorProfile @relation("DoctorConsultations", fields: [doctorId], references: [id])
  slotId        String        @unique
  slot          CalendarSlot  @relation(fields: [slotId], references: [id])
  consultType   String        // OFFLINE, ONLINE, PHONE, VIDEO
  status        String        @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, RESCHEDULED
  patientName   String?
  patientPhone  String?
  patientEmail  String?
  reason        String?
  cancelReason  String?
  cancelledBy   String?       // PATIENT, DOCTOR
  rescheduledTo String?
  meetingUrl    String?
  price         Int           @default(0)
  isPaid        Boolean       @default(false)
  rating        Float?
  comment       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

// ── Laboratoriya Moduli ─────────────────────────────────────────────────────

enum LabTestStatus {
  PENDING
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model LabOrder {
  id            String        @id @default(uuid())
  patientId     Int
  patient       User          @relation("PatientLabOrders", fields: [patientId], references: [id])
  doctorId      Int?
  doctor        User?         @relation("DoctorLabOrders", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application?  @relation(fields: [applicationId], references: [id])
  status        LabTestStatus @default(PENDING)
  totalPrice    Int           @default(0)
  notes         String?
  sampleDate    DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tests         LabTest[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model LabTest {
  id          String        @id @default(uuid())
  orderId     String
  order       LabOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testCode    String
  testName    String
  category    String        // BLOOD, URINE, HORMONE, BIOCHEMISTRY, etc.
  status      LabTestStatus @default(PENDING)
  result      Json?
  resultText  String?
  normalRange String?
  unit        String?
  price       Int           @default(0)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([category])
}

// ── Dorixona Moduli ─────────────────────────────────────────────────────────

enum PrescriptionStatus {
  ACTIVE
  FILLED
  PARTIALLY_FILLED
  EXPIRED
  CANCELLED
}

model Prescription {
  id            String             @id @default(uuid())
  patientId     Int
  patient       User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctorId      Int
  doctor        User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application?       @relation(fields: [applicationId], references: [id])
  status        PrescriptionStatus @default(ACTIVE)
  diagnosis     String?
  notes         String?
  validUntil    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  items         PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String?
  medicine       Medicine?    @relation(fields: [medicineId], references: [id])
  medicineName   String
  dosage         String       // "500mg"
  frequency      String       // "2 marta kuniga"
  duration       String       // "7 kun"
  quantity       Int          @default(1)
  instructions   String?      // "Ovqatdan keyin"
  isFilled       Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([prescriptionId])
}

model Medicine {
  id              String             @id @default(uuid())
  name            String
  nameRu          String?
  genericName     String?
  manufacturer    String?
  category        String             // ANTIBIOTIC, PAINKILLER, VITAMIN, etc.
  form            String             // TABLET, CAPSULE, SYRUP, INJECTION, etc.
  dosage          String?            // "500mg"
  price           Int                @default(0)
  inStock         Boolean            @default(true)
  stockQuantity   Int                @default(0)
  requiresRx      Boolean            @default(false) // Retsept talab qiladimi
  description     String?
  sideEffects     String?
  contraindications String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  prescriptionItems PrescriptionItem[]

  @@index([category])
  @@index([name])
}

// ── EMR (Kasallik Tarixi) Moduli ────────────────────────────────────────────

model MedicalRecord {
  id            String    @id @default(uuid())
  patientId     Int
  patient       User      @relation("PatientMedicalRecords", fields: [patientId], references: [id])
  doctorId      Int
  doctor        User      @relation("DoctorMedicalRecords", fields: [doctorId], references: [id])
  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])
  recordType    String    // CONSULTATION, EXAMINATION, DIAGNOSIS, PROCEDURE, FOLLOW_UP
  icdCode       String?   // ICD-10 kasallik kodi
  diagnosis     String?
  symptoms      String[]
  findings      String?
  treatment     String?
  notes         String?
  vitals        Json?     // { bloodPressure, heartRate, temperature, weight, height }
  attachments   String[]  // fayl URL lari
  isConfidential Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([icdCode])
  @@index([recordType])
}

model Allergy {
  id         String   @id @default(uuid())
  patientId  Int
  patient    User     @relation("PatientAllergies", fields: [patientId], references: [id])
  allergen   String
  severity   String   // MILD, MODERATE, SEVERE
  reaction   String?
  notes      String?
  reportedAt DateTime @default(now())

  @@index([patientId])
  @@unique([patientId, allergen])
}
