{
  "name": "@medsmart/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./disease": {
      "types": "./src/disease.ts",
      "default": "./src/disease.ts"
    },
    "./symptom": {
      "types": "./src/symptom.ts",
      "default": "./src/symptom.ts"
    },
    "./triage": {
      "types": "./src/triage.ts",
      "default": "./src/triage.ts"
    },
    "./matcher-wizard": {
      "types": "./src/matcher-wizard.ts",
      "default": "./src/matcher-wizard.ts"
    },
    "./generated": {
      "types": "./src/generated.ts",
      "default": "./src/generated.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "openapi-typescript ../../server/openapi.json -o src/generated.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "openapi-typescript": "^7.13.0"
  }
}
