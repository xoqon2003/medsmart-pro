# ═══════════════════════════════════════════════════════════════
# MedSmart Pro — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Nusxa oling: cp .env.example .env  va kerakli qiymatlarni to'ldiring.

# Backend API URL
VITE_API_URL=http://localhost:3000/api/v1

# Mock mode: haqiqiy backend yo'qligida frontend mock data bilan ishlaydi.
# Backend ishlagach, bu qiymatni "true" ga o'zgartiring.
VITE_USE_REAL_API=false

# ── Feature flags ─────────────────────────────────────────────────────────────
# Prod default = false (barcha yangi modullar disabled holda chiqadi).
# Staging / demo: true qiling.

# Disease KB moduli (kasalliklar bazasi, shifokor inbox, KB admin paneli).
# Backend tomonda ham APP_FEATURE_DISEASE_KB="true" bo'lishi kerak (server/.env).
VITE_FEATURE_DISEASE_KB=false
